{{ 'pi-base.css' | asset_url | stylesheet_tag }}
{{ 'section-pi-hero.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pi-reveal.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign desktop_height = section.settings.min_height_desktop | default: 'medium'
  assign mobile_height = section.settings.min_height_mobile | default: 'medium'
  assign color_scheme = section.settings.color_scheme | default: 'dark'
  assign text_alignment = section.settings.text_alignment | default: 'left'
  assign overlay_opacity = section.settings.overlay_opacity | default: 40
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}


<section
  id="Hero-{{ section.id }}"
  class="pi-hero pi-hero--mobile-{{ mobile_height }} pi-hero--desktop-{{ desktop_height }}{% if color_scheme == 'light' %} pi-hero--light{% endif %}"
>
  {%- comment -%} Background Images — <picture> for art direction {%- endcomment -%}
  <div class="pi-hero__media">
    {%- if section.settings.image_desktop != blank or section.settings.image_mobile != blank -%}
      <picture>
        {%- if section.settings.image_desktop != blank -%}
          <source
            media="(min-width: 750px)"
            srcset="
              {{ section.settings.image_desktop | image_url: width: 1100 }} 1100w,
              {{ section.settings.image_desktop | image_url: width: 1500 }} 1500w,
              {{ section.settings.image_desktop | image_url: width: 1780 }} 1780w,
              {{ section.settings.image_desktop | image_url: width: 2000 }} 2000w,
              {{ section.settings.image_desktop | image_url: width: 3000 }} 3000w
            "
            sizes="100vw"
          >
        {%- endif -%}

        {%- if section.settings.image_mobile != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="
              {{ section.settings.image_mobile | image_url: width: 375 }} 375w,
              {{ section.settings.image_mobile | image_url: width: 550 }} 550w,
              {{ section.settings.image_mobile | image_url: width: 750 }} 750w
            "
            sizes="100vw"
          >
        {%- endif -%}

        {%- comment -%} Fallback <img> — uses mobile if both exist, desktop otherwise {%- endcomment -%}
        {%- if section.settings.image_mobile != blank -%}
          {{
            section.settings.image_mobile
            | image_url: width: 1500
            | image_tag:
              loading: 'eager',
              fetchpriority: fetch_priority,
              sizes: '100vw',
              widths: '375, 550, 750, 1100, 1500',
              alt: section.settings.image_mobile.alt | default: section.settings.heading
          }}
        {%- elsif section.settings.image_desktop != blank -%}
          {{
            section.settings.image_desktop
            | image_url: width: 1500
            | image_tag:
              loading: 'eager',
              fetchpriority: fetch_priority,
              sizes: '100vw',
              widths: '375, 550, 750, 1100, 1500, 1780, 2000',
              alt: section.settings.image_desktop.alt | default: section.settings.heading
          }}
        {%- endif -%}
      </picture>
    {%- else -%}
      {%- comment -%} Placeholder when no images selected {%- endcomment -%}
      <div style="width:100%;height:100%;background:var(--pi-deep-blue);"></div>
    {%- endif -%}
  </div>

  {%- comment -%} Overlay {%- endcomment -%}
  {%- assign ov_decimal = overlay_opacity | times: 1.0 | divided_by: 100.0 -%}
  {%- if color_scheme == 'dark' -%}
    {%- assign ov_a1 = 1.0 | times: ov_decimal -%}
    {%- assign ov_a2 = 0.6 | times: ov_decimal -%}
    {%- assign ov_a3 = 0.3 | times: ov_decimal -%}
    <div class="pi-hero__overlay" style="background: linear-gradient(to top, rgba(21,45,56,{{ ov_a1 }}) 0%, rgba(21,45,56,{{ ov_a2 }}) 50%, rgba(21,45,56,{{ ov_a3 }}) 100%);"></div>
  {%- else -%}
    {%- assign ov_a1 = 0.9 | times: ov_decimal -%}
    {%- assign ov_a2 = 0.4 | times: ov_decimal -%}
    {%- assign ov_a3 = 0.1 | times: ov_decimal -%}
    <div class="pi-hero__overlay" style="background: linear-gradient(to top, rgba(255,255,255,{{ ov_a1 }}) 0%, rgba(255,255,255,{{ ov_a2 }}) 50%, rgba(255,255,255,{{ ov_a3 }}) 100%);"></div>
  {%- endif -%}

  {%- comment -%} Text Content {%- endcomment -%}
  <div class="pi-hero__content pi-hero__content--{{ text_alignment }}">
    {%- if section.settings.accent_text != blank -%}
      <span class="pi-hero__accent">{{ section.settings.accent_text }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="pi-hero__heading pi-heading--hero">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.body_text != blank -%}
      <p class="pi-hero__body">{{ section.settings.body_text }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <div class="pi-hero__cta">
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="pi-btn pi-btn--{{ section.settings.button_style | default: 'primary' }}"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "PI Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image",
      "info": "Recommended: 2000 x 800px minimum. Shown at 750px+ viewports."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "info": "Recommended: 750 x 900px minimum. Shown below 750px."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "accent_text",
      "label": "Accent text",
      "info": "Displayed above heading in gold italic (Libre Baskerville)."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Next Adventure Starts Here"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "default": "primary",
      "options": [
        { "value": "primary", "label": "Primary (Gold)" },
        { "value": "secondary", "label": "Secondary (Outline)" },
        { "value": "green", "label": "Green" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select",
      "id": "min_height_desktop",
      "label": "Desktop minimum height",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small (500px)" },
        { "value": "medium", "label": "Medium (600px)" },
        { "value": "large", "label": "Large (700px)" },
        { "value": "full", "label": "Full screen" }
      ]
    },
    {
      "type": "select",
      "id": "min_height_mobile",
      "label": "Mobile minimum height",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small (400px)" },
        { "value": "medium", "label": "Medium (500px)" },
        { "value": "large", "label": "Large (600px)" }
      ]
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "dark",
      "options": [
        { "value": "dark", "label": "Dark overlay" },
        { "value": "light", "label": "Light overlay" }
      ]
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "PI Hero",
      "settings": {
        "heading": "Your Next Adventure Starts Here",
        "accent_text": "Pawleys Island, SC",
        "button_label": "Shop Now",
        "button_style": "primary",
        "text_alignment": "left",
        "min_height_desktop": "large",
        "min_height_mobile": "medium",
        "color_scheme": "dark",
        "overlay_opacity": 40
      }
    }
  ]
}
{% endschema %}
