{{ 'pi-base.css' | asset_url | stylesheet_tag }}
{{ 'section-pi-brand-banner.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pi-reveal.js' | asset_url }}" defer></script>

{%- liquid
  assign bg = section.settings.background_color
  assign dark = false
  if bg == 'deep-blue' or bg == 'midnight'
    assign dark = true
  endif
-%}

<section
  class="pi-section pi-brand-banner pi-brand-banner--bg-{{ bg }}{% if dark %} pi-section--dark{% endif %}"
  id="section-{{ section.id }}"
>
  <div class="pi-section__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="pi-heading pi-heading--h3 pi-brand-banner__heading pi-reveal">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="pi-brand-banner__logos pi-reveal{% if section.settings.grayscale %} pi-brand-banner__logos--grayscale{% endif %}"
        style="--pi-logo-height: {{ section.settings.logo_height }}px;"
      >
        {%- for block in section.blocks -%}
          {%- if block.settings.logo != blank -%}
            <div class="pi-brand-banner__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="pi-brand-banner__link" aria-label="{{ block.settings.brand_name | default: 'Brand' }}">
              {%- endif -%}

              <img
                src="{{ block.settings.logo | image_url: height: 160 }}"
                alt="{{ block.settings.brand_name | default: 'Brand logo' | escape }}"
                class="pi-brand-banner__logo"
                width="{{ block.settings.logo.width }}"
                height="{{ block.settings.logo.height }}"
                loading="lazy"
              >

              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "PI — Brand Banner",
  "tag": "section",
  "class": "pi-brand-banner-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Brands We Carry"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background color",
      "options": [
        { "value": "warm-white", "label": "Warm White" },
        { "value": "white", "label": "White" },
        { "value": "cream", "label": "Cream" },
        { "value": "deep-blue", "label": "Deep Blue" },
        { "value": "midnight", "label": "Midnight" }
      ],
      "default": "warm-white"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height (px)",
      "min": 30,
      "max": 80,
      "step": 5,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "Grayscale logos (color on hover)",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "limit": 20,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand name",
          "info": "Used for alt text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PI — Brand Banner",
      "blocks": []
    }
  ]
}
{% endschema %}
