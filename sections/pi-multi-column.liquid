{{ 'pi-base.css' | asset_url | stylesheet_tag }}
{{ 'section-pi-multi-column.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bg = section.settings.background_color
  assign dark_backgrounds = 'deep-blue,midnight'
  assign is_dark = false
  if dark_backgrounds contains bg
    assign is_dark = true
  endif
  assign card_style = section.settings.card_style
-%}

<div
  class="pi-section pi-multi-column{% if is_dark %} pi-section--dark{% endif %} pi-multi-column--bg-{{ bg }}"
  id="Section-{{ section.id }}"
>
  <div class="pi-section__inner">
    {%- if section.settings.label != blank or section.settings.heading != blank or section.settings.body_text != blank -%}
      <div class="pi-multi-column__header pi-reveal">
        {%- if section.settings.label != blank -%}
          <span class="pi-label">{{ section.settings.label }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="pi-heading pi-heading--h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body_text != blank -%}
          <p class="pi-body pi-body--large pi-multi-column__body">{{ section.settings.body_text }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="pi-multi-column__grid pi-stagger"
        style="--pi-grid-columns: {{ section.settings.columns_desktop }};"
      >
        {%- for block in section.blocks -%}
          {%- liquid
            assign image_ratio = block.settings.image_ratio
            assign ratio_class = 'pi-multi-column__image-wrap--' | append: image_ratio
          -%}

          <div
            class="pi-multi-column__card pi-multi-column__card--{{ card_style }}{% if is_dark %} pi-multi-column__card--dark{% endif %} pi-reveal"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              <div class="pi-multi-column__image-wrap {{ ratio_class }}">
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    class: 'pi-multi-column__image pi-img-cover',
                    loading: 'lazy',
                    widths: '400, 600, 800',
                    sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw'
                }}
              </div>
            {%- endif -%}

            <div class="pi-multi-column__content">
              {%- if block.settings.heading != blank -%}
                <h3 class="pi-heading pi-heading--h3 pi-multi-column__heading">
                  {{ block.settings.heading }}
                </h3>
              {%- endif -%}

              {%- if block.settings.body_text != blank -%}
                <div class="pi-body pi-multi-column__text">
                  {{ block.settings.body_text }}
                </div>
              {%- endif -%}

              {%- if block.settings.button_label != blank -%}
                <a
                  href="{{ block.settings.button_link }}"
                  class="pi-btn pi-btn--primary pi-multi-column__btn"
                  {% if block.settings.button_link == blank %}aria-disabled="true"{% endif %}
                >
                  {{ block.settings.button_label | escape }}
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script src="{{ 'pi-reveal.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "PI Multi-Column",
  "tag": "section",
  "class": "pi-multi-column-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Multi-Column"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columns on desktop"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background color",
      "options": [
        { "value": "warm-white", "label": "Warm White" },
        { "value": "white", "label": "White" },
        { "value": "cream", "label": "Cream" },
        { "value": "deep-blue", "label": "Deep Blue" },
        { "value": "midnight", "label": "Midnight" }
      ],
      "default": "warm-white"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card style",
      "options": [
        { "value": "flat", "label": "Flat" },
        { "value": "bordered", "label": "Bordered" },
        { "value": "filled", "label": "Filled" }
      ],
      "default": "bordered"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_ratio",
          "label": "Image ratio",
          "options": [
            { "value": "1-1", "label": "1:1 Square" },
            { "value": "4-5", "label": "4:5 Portrait" },
            { "value": "16-9", "label": "16:9 Landscape" }
          ],
          "default": "4-5"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Column heading"
        },
        {
          "type": "textarea",
          "id": "body_text",
          "label": "Body text",
          "default": "Pair text with an image to focus on your chosen product, collection, or blog post."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PI Multi-Column",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
