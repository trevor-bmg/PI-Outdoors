{{ 'pi-base.css' | asset_url | stylesheet_tag }}
{{ 'section-pi-cta-banner.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pi-reveal.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign bg_style = section.settings.background_style | default: 'deep-blue'
  assign text_alignment = section.settings.text_alignment | default: 'center'
  assign overlay_opacity = section.settings.overlay_opacity | default: 50
  assign has_image_bg = false
  if bg_style == 'image' and section.settings.background_image != blank
    assign has_image_bg = true
  endif
-%}

{%- if has_image_bg -%}
  {%- style -%}
    #CtaBanner-{{ section.id }} .pi-cta-banner__overlay {
      opacity: {{ overlay_opacity | divided_by: 100.0 }};
    }
  {%- endstyle -%}
{%- endif -%}

<section
  id="CtaBanner-{{ section.id }}"
  class="pi-cta-banner{% unless has_image_bg %} pi-cta-banner--{{ bg_style }}{% endunless %}"
>
  {%- if has_image_bg -%}
    <div class="pi-cta-banner__media">
      {{
        section.settings.background_image
        | image_url: width: 2000
        | image_tag:
          loading: 'lazy',
          sizes: '100vw',
          widths: '375, 750, 1100, 1500, 2000',
          alt: section.settings.background_image.alt | default: section.settings.heading
      }}
    </div>
    <div class="pi-cta-banner__overlay"></div>
  {%- endif -%}

  <div class="pi-cta-banner__inner pi-cta-banner__inner--{{ text_alignment }} pi-reveal">
    {%- if section.settings.label != blank -%}
      <span class="pi-cta-banner__label">{{ section.settings.label }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="pi-cta-banner__heading pi-heading--h2">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.body_text != blank -%}
      <p class="pi-cta-banner__body">{{ section.settings.body_text }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <div class="pi-cta-banner__cta">
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="pi-btn pi-btn--{{ section.settings.button_style | default: 'primary' }}"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "PI CTA Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_style",
      "label": "Background style",
      "default": "deep-blue",
      "options": [
        { "value": "deep-blue", "label": "Deep Blue" },
        { "value": "midnight", "label": "Midnight" },
        { "value": "marsh-green", "label": "Marsh Green" },
        { "value": "gold", "label": "Gold" },
        { "value": "image", "label": "Image" }
      ]
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Only used when background style is set to \"Image\"."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "%",
      "info": "Only applies to image backgrounds."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "info": "Small uppercase text above the heading.",
      "default": "Visit Us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stop In and See Us"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get Directions"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "default": "primary",
      "options": [
        { "value": "primary", "label": "Primary (Gold)" },
        { "value": "secondary", "label": "Secondary (Outline)" },
        { "value": "green", "label": "Green" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PI CTA Banner",
      "settings": {
        "background_style": "deep-blue",
        "label": "Visit Us",
        "heading": "Stop In and See Us",
        "body_text": "Whether you're gearing up for your next trip or just browsing, we'd love to help.",
        "button_label": "Get Directions",
        "button_style": "primary",
        "text_alignment": "center"
      }
    }
  ]
}
{% endschema %}
