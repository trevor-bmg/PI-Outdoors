{{ 'pi-base.css' | asset_url | stylesheet_tag }}
{{ 'section-pi-collection-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bg = section.settings.background_color
  assign dark_backgrounds = 'deep-blue,midnight'
  assign is_dark = false
  if dark_backgrounds contains bg
    assign is_dark = true
  endif
-%}

<div
  class="pi-section pi-collection-grid{% if is_dark %} pi-section--dark{% endif %} pi-collection-grid--bg-{{ bg }}"
  id="Section-{{ section.id }}"
>
  <div class="pi-section__inner">
    {%- if section.settings.label != blank or section.settings.heading != blank or section.settings.body_text != blank -%}
      <div class="pi-collection-grid__header pi-reveal">
        {%- if section.settings.label != blank -%}
          <span class="pi-label">{{ section.settings.label }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="pi-heading pi-heading--h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body_text != blank -%}
          <p class="pi-body pi-body--large pi-collection-grid__body">{{ section.settings.body_text }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="pi-collection-grid__grid pi-stagger"
        style="--pi-grid-columns: {{ section.settings.columns_desktop }};"
      >
        {%- for block in section.blocks -%}
          {%- liquid
            assign collection = block.settings.collection
            assign has_collection = false
            if collection != blank and collection != empty
              assign has_collection = true
            endif

            assign card_image = nil
            if block.settings.custom_image != blank
              assign card_image = block.settings.custom_image
            elsif has_collection and collection.image != blank
              assign card_image = collection.image
            elsif has_collection and collection.featured_image != blank
              assign card_image = collection.featured_image
            endif

            assign card_title = block.settings.custom_title
            if card_title == blank and has_collection
              assign card_title = collection.title
            endif
            if card_title == blank
              assign card_title = 'Collection'
            endif

            assign overlay_opacity = block.settings.overlay_opacity | divided_by: 100.0
          -%}

          <div class="pi-collection-grid__card pi-reveal" {{ block.shopify_attributes }}>
            {%- if has_collection -%}
              <a href="{{ collection.url }}" class="pi-collection-grid__link" aria-label="{{ card_title }}">
            {%- endif -%}

              <div class="pi-collection-grid__image-wrap">
                {%- if card_image != nil -%}
                  {{
                    card_image
                    | image_url: width: 800
                    | image_tag:
                      class: 'pi-collection-grid__image pi-img-cover',
                      loading: 'lazy',
                      widths: '400, 600, 800',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw'
                  }}
                {%- else -%}
                  <div class="pi-collection-grid__placeholder">
                    {{ 'collection-1' | placeholder_svg_tag: 'pi-collection-grid__placeholder-svg' }}
                  </div>
                {%- endif -%}
                <div
                  class="pi-collection-grid__overlay"
                  style="--pi-overlay-opacity: {{ overlay_opacity }};"
                ></div>
              </div>

              <div class="pi-collection-grid__title-wrap">
                <h3 class="pi-heading pi-heading--h3 pi-collection-grid__title">
                  {{ card_title }}
                </h3>
              </div>

            {%- if has_collection -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script src="{{ 'pi-reveal.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "PI Collection Grid",
  "tag": "section",
  "class": "pi-collection-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Our Collections"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background color",
      "options": [
        { "value": "warm-white", "label": "Warm White" },
        { "value": "white", "label": "White" },
        { "value": "cream", "label": "Cream" },
        { "value": "deep-blue", "label": "Deep Blue" },
        { "value": "midnight", "label": "Midnight" }
      ],
      "default": "warm-white"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 8,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom image",
          "info": "Overrides the collection image."
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title",
          "info": "Overrides the collection title."
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "default": 30,
          "unit": "%",
          "label": "Image overlay opacity"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PI Collection Grid",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
