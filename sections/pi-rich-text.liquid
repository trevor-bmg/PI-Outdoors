{{ 'pi-base.css' | asset_url | stylesheet_tag }}
{{ 'section-pi-rich-text.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pi-reveal.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign bg = section.settings.background_color
  assign is_dark = false
  if bg == 'deep-blue' or bg == 'midnight'
    assign is_dark = true
  endif
  assign alignment = section.settings.text_alignment
  assign width = section.settings.content_width
  assign padding = section.settings.vertical_padding
-%}

<section
  class="pi-section pi-rich-text-section pi-rich-text-section--bg-{{ bg }} pi-rich-text-section--padding-{{ padding }}{% if is_dark %} pi-rich-text-section--dark{% endif %}"
  id="section-{{ section.id }}"
>
  <div class="pi-section__inner pi-rich-text pi-rich-text--{{ alignment }}">
    <div class="pi-rich-text__inner pi-rich-text__inner--{{ width }}">

      {%- if section.settings.label != blank -%}
        <span class="pi-label pi-rich-text__label pi-reveal">
          {{ section.settings.label }}
        </span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="pi-heading pi-heading--h2 pi-rich-text__heading pi-reveal">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.heading != blank or section.settings.label != blank -%}
        <hr class="pi-divider pi-rich-text__divider pi-reveal">
      {%- endif -%}

      {%- if section.settings.accent_text != blank -%}
        <p class="pi-accent pi-rich-text__accent pi-reveal">
          {{ section.settings.accent_text }}
        </p>
      {%- endif -%}

      {%- if section.settings.body_text != blank -%}
        <div class="pi-body pi-rich-text__body pi-reveal">
          {{ section.settings.body_text }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="pi-rich-text__button pi-reveal">
          <a
            href="{{ section.settings.button_link }}"
            class="pi-btn pi-btn--{{ section.settings.button_style }}"
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "PI Rich Text",
  "tag": "section",
  "class": "pi-rich-text-section",
  "settings": [
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "accent_text",
      "label": "Accent text",
      "info": "Displayed in Libre Baskerville italic."
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Use this section for introductory text, about content, policies, or any centered text block.</p>"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "default": "primary",
      "options": [
        { "value": "primary", "label": "Primary (Gold)" },
        { "value": "secondary", "label": "Secondary (Outline)" },
        { "value": "green", "label": "Green" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "medium",
      "options": [
        { "value": "narrow", "label": "Narrow (600px)" },
        { "value": "medium", "label": "Medium (800px)" },
        { "value": "wide", "label": "Wide (1000px)" }
      ]
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background color",
      "default": "warm-white",
      "options": [
        { "value": "warm-white", "label": "Warm White" },
        { "value": "white", "label": "White" },
        { "value": "cream", "label": "Cream" },
        { "value": "deep-blue", "label": "Deep Blue" },
        { "value": "midnight", "label": "Midnight" }
      ]
    },
    {
      "type": "select",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PI Rich Text",
      "category": "PI Outdoors"
    }
  ]
}
{% endschema %}
