{{ 'pi-base.css' | asset_url | stylesheet_tag }}
{{ 'section-pi-image-gallery.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pi-reveal.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign bg = section.settings.background_color | default: 'warm-white'
  assign is_dark = false
  if bg == 'deep-blue' or bg == 'midnight'
    assign is_dark = true
  endif
  assign cols = section.settings.columns_desktop | default: 3
  assign ratio = section.settings.image_ratio | default: 'auto'
  assign gap = section.settings.gap_size | default: 'medium'
-%}

{%- style -%}
  #ImageGallery-{{ section.id }} {
    {%- case bg -%}
      {%- when 'warm-white' -%} background-color: var(--pi-warm-white);
      {%- when 'white' -%}      background-color: var(--pi-white);
      {%- when 'cream' -%}      background-color: var(--pi-cream);
      {%- when 'deep-blue' -%}  background-color: var(--pi-deep-blue);
      {%- when 'midnight' -%}   background-color: var(--pi-midnight);
    {%- endcase -%}
  }

  #ImageGallery-{{ section.id }} .pi-gallery__grid {
    --pi-gallery-cols: {{ cols }};
    {%- case gap -%}
      {%- when 'small' -%}  --pi-gallery-gap: 8px;
      {%- when 'medium' -%} --pi-gallery-gap: 16px;
      {%- when 'large' -%}  --pi-gallery-gap: 24px;
    {%- endcase -%}
  }

  {%- unless ratio == 'auto' -%}
    #ImageGallery-{{ section.id }} .pi-gallery__item {
      {%- case ratio -%}
        {%- when 'square' -%} aspect-ratio: 1 / 1;
        {%- when 'portrait' -%} aspect-ratio: 4 / 5;
      {%- endcase -%}
    }
  {%- endunless -%}
{%- endstyle -%}

<section
  id="ImageGallery-{{ section.id }}"
  class="pi-section pi-gallery{% if is_dark %} pi-section--dark{% endif %}"
>
  <div class="pi-section__inner">

    {%- comment -%} Section header {%- endcomment -%}
    {%- if section.settings.label != blank or section.settings.heading != blank or section.settings.body_text != blank -%}
      <div class="pi-gallery__header pi-reveal">
        {%- if section.settings.label != blank -%}
          <span class="pi-label">{{ section.settings.label }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="pi-heading pi-heading--h2">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.body_text != blank -%}
          <p class="pi-body pi-body--large pi-gallery__intro">
            {{ section.settings.body_text }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Image grid {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="pi-gallery__grid pi-stagger">
        {%- for block in section.blocks -%}
          <div class="pi-gallery__item pi-reveal" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="
                  {{ block.settings.image | image_url: width: 400 }} 400w,
                  {{ block.settings.image | image_url: width: 600 }} 600w,
                  {{ block.settings.image | image_url: width: 800 }} 800w,
                  {{ block.settings.image | image_url: width: 1000 }} 1000w
                "
                sizes="(max-width: 749px) calc(50vw - 24px), calc(100vw / {{ cols }} - 32px)"
                alt="{{ block.settings.image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                class="pi-gallery__img"
              >
            {%- else -%}
              <div class="pi-gallery__placeholder">
                {{ 'image' | placeholder_svg_tag: 'pi-gallery__placeholder-svg' }}
              </div>
            {%- endif -%}

            {%- if block.settings.caption != blank -%}
              <div class="pi-gallery__overlay">
                <span class="pi-gallery__caption">{{ block.settings.caption }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "PI Image Gallery",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Gallery"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "In-Store Inventory"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Natural (auto)" },
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (4:5)" }
      ]
    },
    {
      "type": "select",
      "id": "gap_size",
      "label": "Gap between images",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small (8px)" },
        { "value": "medium", "label": "Medium (16px)" },
        { "value": "large", "label": "Large (24px)" }
      ]
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background color",
      "default": "warm-white",
      "options": [
        { "value": "warm-white", "label": "Warm White" },
        { "value": "white", "label": "White" },
        { "value": "cream", "label": "Cream" },
        { "value": "deep-blue", "label": "Deep Blue" },
        { "value": "midnight", "label": "Midnight" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 20,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "info": "Optional — shown on hover."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PI Image Gallery",
      "settings": {
        "label": "Gallery",
        "heading": "In-Store Inventory",
        "columns_desktop": 3,
        "image_ratio": "auto",
        "gap_size": "medium",
        "background_color": "warm-white"
      },
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
