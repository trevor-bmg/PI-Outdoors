{{ 'section-pi-header.css' | asset_url | stylesheet_tag }}
{{ 'pi-base.css' | asset_url | stylesheet_tag }}

<script src="{{ 'pi-header.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign menu = section.settings.menu
  assign utility_menu = section.settings.utility_menu
  assign show_utility = section.settings.show_utility_bar
  assign sticky = section.settings.enable_sticky

  case section.settings.color_scheme
    when 'midnight'
      assign header_class = 'pi-header--midnight'
    when 'dark-blue'
      assign header_class = 'pi-header--dark-blue'
    else
      assign header_class = ''
  endcase
-%}

<pi-header>
  {%- comment -%}── Utility Bar ──{%- endcomment -%}
  {%- if show_utility -%}
    <div class="pi-header-utility">
      <div class="pi-header-utility__inner">
        <div class="pi-header-utility__text">
          {%- if section.settings.utility_text != blank -%}
            {{ section.settings.utility_text }}
          {%- endif -%}
        </div>
        {%- if utility_menu != blank -%}
          <nav aria-label="Utility navigation">
            <ul class="pi-header-utility__nav">
              {%- for link in linklists[utility_menu].links -%}
                <li>
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}── Main Header ──{%- endcomment -%}
  <div
    class="pi-header-wrapper{% if sticky %} pi-header-wrapper--sticky{% endif %}"
    data-pi-header-wrapper
  >
    <header class="pi-header {{ header_class }}" data-pi-header role="banner">
      <div class="pi-header__inner">

        {%- comment -%}── Hamburger (mobile) ──{%- endcomment -%}
        <button
          class="pi-header__hamburger"
          data-pi-drawer-open
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="pi-mobile-drawer"
          type="button"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>

        {%- comment -%}── Logo ──{%- endcomment -%}
        <div class="pi-header__logo">
          {%- if request.page_type == 'index' -%}
            <h1 style="margin:0;line-height:0;">
          {%- endif -%}

          <a href="{{ routes.root_url }}" class="pi-header__logo-link">
            {%- if section.settings.logo != blank -%}
              {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
              {%- assign logo_width = section.settings.logo_width -%}
              {%- assign logo_height = logo_width | divided_by: section.settings.logo.aspect_ratio -%}
              {%- capture sizes -%}(max-width: {{ logo_width | times: 2 }}px) 50vw, {{ logo_width }}px{%- endcapture -%}
              {%- capture widths -%}{{ logo_width }}, {{ logo_width | times: 1.5 | round }}, {{ logo_width | times: 2 }}{%- endcapture -%}
              {{
                section.settings.logo
                | image_url: width: 500
                | image_tag:
                  class: 'pi-header__logo-img',
                  widths: widths,
                  height: logo_height,
                  width: logo_width,
                  alt: logo_alt,
                  sizes: sizes,
                  preload: true
              }}
            {%- else -%}
              <span class="pi-header__logo-text">{{ shop.name }}</span>
            {%- endif -%}
          </a>

          {%- if request.page_type == 'index' -%}
            </h1>
          {%- endif -%}
        </div>

        {%- comment -%}── Desktop Navigation ──{%- endcomment -%}
        {%- if menu != blank -%}
          <nav aria-label="Primary navigation">
            <ul class="pi-header__nav">
              {%- for link in linklists[menu].links -%}
                <li
                  class="pi-header__nav-item"
                  {%- if link.links.size > 0 %} data-pi-has-dropdown{% endif -%}
                >
                  <a
                    href="{{ link.url }}"
                    class="pi-header__nav-link{% if link.active or link.child_active %} pi-header__nav-link--active{% endif %}{% if link.links.size > 0 %} pi-header__nav-link--has-children{% endif %}"
                    {%- if link.links.size > 0 %}
                      aria-haspopup="true"
                      aria-expanded="false"
                    {%- endif -%}
                  >
                    {{ link.title | escape }}
                  </a>

                  {%- if link.links.size > 0 -%}
                    <ul class="pi-header__dropdown" role="menu">
                      {%- for child_link in link.links -%}
                        <li role="none">
                          <a
                            href="{{ child_link.url }}"
                            class="pi-header__dropdown-link{% if child_link.active %} pi-header__dropdown-link--active{% endif %}"
                            role="menuitem"
                          >
                            {{ child_link.title | escape }}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}

        {%- comment -%}── Icons (search + cart) ──{%- endcomment -%}
        <div class="pi-header__icons">
          {%- comment -%}Search icon — links to search page{%- endcomment -%}
          <a href="{{ routes.search_url }}" class="pi-header__icon" aria-label="Search">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="11" cy="11" r="7"/>
              <line x1="16.5" y1="16.5" x2="21" y2="21"/>
            </svg>
          </a>

          {%- comment -%}Cart icon with count bubble{%- endcomment -%}
          <a href="{{ routes.cart_url }}" class="pi-header__icon" id="pi-cart-icon-bubble" aria-label="Cart">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
            {%- if cart != empty -%}
              <span class="pi-header__cart-count" aria-hidden="true">
                {%- if cart.item_count < 100 -%}{{ cart.item_count }}{%- else -%}99+{%- endif -%}
              </span>
              <span class="pi-visually-hidden">{{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }} in cart</span>
            {%- endif -%}
          </a>
        </div>

      </div>
    </header>
  </div>

  {%- comment -%}── Mobile Drawer ──{%- endcomment -%}
  <div class="pi-drawer-overlay" data-pi-drawer-overlay aria-hidden="true"></div>
  <nav
    class="pi-drawer"
    id="pi-mobile-drawer"
    data-pi-drawer
    role="dialog"
    aria-modal="true"
    aria-label="Mobile menu"
  >
    {%- comment -%}Drawer header{%- endcomment -%}
    <div class="pi-drawer__header">
      {%- if section.settings.logo != blank -%}
        <a href="{{ routes.root_url }}" class="pi-header__logo-link" tabindex="-1" aria-hidden="true">
          {%- assign drawer_logo_width = 120 -%}
          {%- assign drawer_logo_height = drawer_logo_width | divided_by: section.settings.logo.aspect_ratio -%}
          {{
            section.settings.logo
            | image_url: width: 240
            | image_tag:
              class: 'pi-header__logo-img',
              width: drawer_logo_width,
              height: drawer_logo_height,
              alt: '',
              loading: 'lazy'
          }}
        </a>
      {%- else -%}
        <span class="pi-header__logo-text" style="font-size: 1rem;">{{ shop.name }}</span>
      {%- endif -%}

      <button
        class="pi-drawer__close"
        data-pi-drawer-close
        aria-label="Close menu"
        type="button"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    {%- comment -%}Drawer search{%- endcomment -%}
    <div class="pi-drawer__search">
      <form action="{{ routes.search_url }}" method="get" class="pi-drawer__search-form" role="search">
        <input
          type="search"
          name="q"
          class="pi-drawer__search-input"
          placeholder="Search..."
          aria-label="Search products"
          autocomplete="off"
        >
        <button type="submit" class="pi-drawer__search-btn" aria-label="Submit search">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/>
            <line x1="16.5" y1="16.5" x2="21" y2="21"/>
          </svg>
        </button>
      </form>
    </div>

    {%- comment -%}Drawer navigation{%- endcomment -%}
    <div class="pi-drawer__nav">
      {%- if menu != blank -%}
        <ul class="pi-drawer__menu">
          {%- for link in linklists[menu].links -%}
            <li class="pi-drawer__menu-item" {% if link.links.size > 0 %}data-pi-drawer-item{% endif %}>
              <div style="display: flex; align-items: center;">
                <a
                  href="{{ link.url }}"
                  class="pi-drawer__menu-link{% if link.active or link.child_active %} pi-drawer__menu-link--active{% endif %}"
                  style="flex: 1;"
                >
                  {{ link.title | escape }}
                </a>
                {%- if link.links.size > 0 -%}
                  <button
                    class="pi-drawer__menu-toggle"
                    data-pi-accordion-toggle
                    aria-expanded="false"
                    aria-label="Expand {{ link.title | escape }} submenu"
                    type="button"
                    style="margin-right: 1rem;"
                  >
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <polyline points="6 9 12 15 18 9"/>
                    </svg>
                  </button>
                {%- endif -%}
              </div>

              {%- if link.links.size > 0 -%}
                <ul class="pi-drawer__submenu" data-pi-submenu>
                  {%- for child_link in link.links -%}
                    <li>
                      <a href="{{ child_link.url }}" class="pi-drawer__submenu-link">
                        {{ child_link.title | escape }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    {%- comment -%}Drawer utility links{%- endcomment -%}
    {%- if utility_menu != blank -%}
      <div class="pi-drawer__utility">
        <ul class="pi-drawer__utility-list">
          {%- for link in linklists[utility_menu].links -%}
            <li>
              <a href="{{ link.url }}" class="pi-drawer__utility-link">
                {{ link.title | escape }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </nav>
</pi-header>

{%- comment -%}── Cart notification support (matches Dawn pattern) ──{%- endcomment -%}
{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification', color_scheme: 'scheme-1' -%}
{%- endif -%}

{%- comment -%}── Structured Data ──{%- endcomment -%}
<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if section.settings.logo %}
      "logo": {{ section.settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_youtube_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {%- assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' -%}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "PI Header",
  "class": "pi-section-header",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 160
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Primary menu"
    },
    {
      "type": "header",
      "content": "Utility bar"
    },
    {
      "type": "checkbox",
      "id": "show_utility_bar",
      "default": true,
      "label": "Show utility bar"
    },
    {
      "type": "link_list",
      "id": "utility_menu",
      "label": "Utility menu",
      "info": "Links shown in the top utility bar (e.g. About Us, Contact)."
    },
    {
      "type": "text",
      "id": "utility_text",
      "label": "Utility bar text",
      "info": "Optional message on the left side (e.g. phone number)."
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "default": true,
      "label": "Enable sticky header"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "deep-blue",
          "label": "Deep Blue"
        },
        {
          "value": "midnight",
          "label": "Midnight"
        },
        {
          "value": "dark-blue",
          "label": "Dark Blue"
        }
      ],
      "default": "deep-blue",
      "label": "Header color scheme"
    }
  ],
  "disabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
